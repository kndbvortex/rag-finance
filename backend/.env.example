# ── RAG app ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag_db

SEARXNG_URL=https://search.kndbvortex.cloud

EMBEDDING_MODEL=intfloat/multilingual-e5-large
RERANKER_MODEL=mixedbread-ai/mxbai-rerank-large-v1

# ── PostgreSQL (shared by RAG + Langfuse) ─────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag_db
POSTGRES_PORT=5432

# ── ClickHouse ────────────────────────────────────────────────────────────
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse

# ── Redis ─────────────────────────────────────────────────────────────────
# REDIS_AUTH=                     # leave empty for no auth

# ── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret

# ── Langfuse ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
# Generate with: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_URL=http://localhost:3000
LANGFUSE_PORT=3000

# Set these after creating an API key inside the Langfuse UI
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ── LLM (Groq) ────────────────────────────────────────────────────────────
# API key gratuite sur https://console.groq.com
GROQ_API_KEY=
LLM_MODEL=llama-3.2-3b-preview
LLM_MAX_TOKENS=2048
